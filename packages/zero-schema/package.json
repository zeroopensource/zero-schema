{
  "name": "@zeroopensource/zero-schema",
  "version": "0.0.4",
  "description": "Reusable generalized schemas for various databases and ORMs",
  "author": "Jigz <jigzpalillo@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/zeroopensource/zero-schema",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeroopensource/zero-schema.git"
  },
  "bugs": {
    "url": "https://github.com/zeroopensource/zero-schema/issues"
  },
  "type": "module",
  "types": "./dist/index.d.cts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "node -e \"require('fs').copyFileSync('../../README.md', 'README.md')\"",
    "lint": "cross-env TIMING=1 eslint \"**/*.ts*\"",
    "build": "tsdown",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "migrate:sqlite": "dotenv -e .env.sqlite.local.dev -- prisma db push --schema dist/sqlite.prisma",
    "migrate:postgresql": "dotenv -e .env.postgresql.local.dev -- prisma db push --schema dist/postgresql.prisma"
  },
  "dependencies": {
    "prisma": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@zeroopensource/zero-cli": "latest",
    "@zeroopensource/zero-id": "latest",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "@hono/zod-openapi": "^1.0.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "dotenv-cli": "^7.2.1",
    "@prisma/studio": "^0.502.0",
    "ts-node": "^10.9.1",
    "fs-extra": "^11.1.1",
    "@types/fs-extra": "^11.0.1",
    "zod": "^4.0.14"
  }
}
